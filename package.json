{
  "name": "rot-rut-avdrag",
  "version": "0.1.0",
  "description": "Beräkna ROT- och RUT-avdrag enligt svenska Skatteverkets regler. Tak, procentsatser, fördelning per person och hushåll, validering av faktureringsfält. Ingen API-anrop — ren funktionspaket.",
  "keywords": [
    "rot",
    "rut",
    "rot-avdrag",
    "rut-avdrag",
    "skatteverket",
    "skatt",
    "swedish",
    "tax",
    "deduction",
    "bygg",
    "hantverk",
    "fakturering"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "lint:fix": "eslint src tests --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.11.10",
    "eslint": "^9.39.4",
    "prettier": "^3.2.4",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.59.2",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=18"
  },
  "overrides": {
    "rollup": "^4.40.0"
  },
  "license": "MIT",
  "author": "Lucas Rosvall <47554985+lucasros98@users.noreply.github.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lucasros98/rot-rut-avdrag.git"
  },
  "bugs": {
    "url": "https://github.com/lucasros98/rot-rut-avdrag/issues"
  },
  "homepage": "https://github.com/lucasros98/rot-rut-avdrag#readme"
}
